<%- include('../partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card p-4 mt-3">
      <h2 class="fw-bold mb-1">Login</h2>
      <p class="text-muted mb-4">Enter your email and password.</p>
      <% if (locals.error && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form method="POST" action="/session/login">
        <div class="mb-3">
          <label class="form-label fw-semibold">Email</label>
          <input class="form-control" name="email" type="email" placeholder="jane@example.com" required />
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Password</label>
          <input class="form-control" name="password" type="password" placeholder="Password" required />
        </div>
        <button class="btn btn-bc w-100">Login</button>
      </form>
      <p class="text-center text-muted mt-3 mb-0">No account yet? <a href="/users/new">Register</a></p>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>