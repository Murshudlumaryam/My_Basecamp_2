<%- include('../partials/header') %>
<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card p-4">
      <h2 class="mb-3">Edit thread</h2>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form method="POST" action="/projects/<%= project.id %>/threads/<%= thread.id %>">
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input class="form-control" type="text" name="title" value="<%= thread.title %>" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea class="form-control" name="body" rows="5"><%= thread.body %></textarea>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-bc" type="submit">Save</button>
          <a href="/projects/<%= project.id %>/threads/<%= thread.id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>