<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MyBasecamp</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: #f7f7f7;
      color: #222;
      font-family: Arial, sans-serif;
    }
    .navbar {
      background: #ffffff;
      border-bottom: 1px solid #d9d9d9;
    }
    .navbar-brand {
      font-weight: 700;
      color: #222 !important;
    }
    .card {
      border: 1px solid #dcdcdc;
      border-radius: 6px;
      box-shadow: none;
      background: #fff;
    }
    .btn-bc {
      background: #2f6fed;
      color: #fff;
      border: 1px solid #2f6fed;
    }
    .btn-bc:hover {
      background: #2459be;
      color: #fff;
      border-color: #2459be;
    }
    .simple-box {
      border: 1px solid #dcdcdc;
      background: #fff;
      padding: 16px;
      border-radius: 6px;
    }
    .muted-box {
      background: #f2f2f2;
      border: 1px solid #e1e1e1;
      border-radius: 6px;
      padding: 12px;
    }
    .page-title {
      margin-bottom: 8px;
    }
    .small-note {
      font-size: 14px;
      color: #666;
    }
    .badge-admin {
      display: inline-block;
      background: #eee;
      color: #333;
      border: 1px solid #ccc;
      font-size: 12px;
      padding: 2px 8px;
      border-radius: 999px;
    }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="/">MyBasecamp</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav ms-auto align-items-center gap-2">
        <% if (locals.currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/projects">Projects</a></li>
          <% if (currentUser.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/users">Users</a></li>
          <% } %>
          <li class="nav-item"><a class="nav-link" href="/projects/new">New project</a></li>
          <li class="nav-item">
            <a class="nav-link" href="/users/<%= currentUser.id %>">
              <%= currentUser.name %>
              <% if (currentUser.role === 'admin') { %><span class="badge-admin ms-1">Admin</span><% } %>
            </a>
          </li>
          <li class="nav-item">
            <form method="POST" action="/session/logout" class="mb-0">
              <button class="btn btn-sm btn-outline-secondary" type="submit">Logout</button>
            </form>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/session/login">Login</a></li>
          <li class="nav-item"><a class="btn btn-bc btn-sm" href="/users/new">Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<div class="container py-4">