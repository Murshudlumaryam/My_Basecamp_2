<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0">Projects</h2>
  <a href="/projects/new" class="btn btn-bc">New project</a>
</div>
<% const projectList = Object.values(projects || {}); %>
<% if (projectList.length === 0) { %>
  <div class="card p-4">
    <h4 class="mb-2">No projects yet</h4>
    <p class="text-muted">You can create a new project from this page.</p>
    <a href="/projects/new" class="btn btn-bc mt-2">Create project</a>
  </div>
<% } else { %>
  <div class="row g-3">
    <% projectList.forEach(p => { %>
      <div class="col-md-4">
        <a href="/projects/<%= p.id %>" class="card p-4 text-decoration-none text-dark d-block h-100">
          <div>
            <h5 class="fw-bold mb-1"><%= p.name %></h5>
            <p class="text-muted mb-3" style="font-size:0.92rem;"><%= p.description || 'No description' %></p>
          </div>
          <div class="mt-3 pt-2 border-top d-flex justify-content-between">
            <small class="text-muted">Owner id: <%= p.owner.substring(0,8) %>...</small>
            <small class="text-muted"><%= new Date(p.createdAt).toLocaleDateString() %></small>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
<% } %>
<%- include('../partials/footer') %>